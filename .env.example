# API runtime
NODE_ENV=production
PORT=3001

# PostgreSQL connection string
DATABASE_URL=postgresql://app:change_me@db-host:5432/devotional

# Session security
SESSION_SECRET=replace_with_a_long_random_secret
SESSION_COOKIE_SAMESITE=lax

# Comma-separated list of allowed frontend origins for CORS.
# Example: CORS_ORIGIN=https://devotional-frontend.onrender.com
CORS_ORIGIN=

# Auth rate limiting
AUTH_RATE_LIMIT_WINDOW_MS=900000
AUTH_RATE_LIMIT_MAX=20

# Optional email scheduler config
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
SMTP_SECURE=false
EMAIL_CHECK_INTERVAL_MS=60000
